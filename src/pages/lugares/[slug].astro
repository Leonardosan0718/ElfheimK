---
// src/pages/lugares/[slug].astro
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const lugares = await getCollection('lugares');
    return lugares.map(lugar => ({
        params: { slug: lugar.id },
        props: { lugar },
    }));
}

const { lugar } = Astro.props;
const { Content } = await render(lugar);
const imagenFondo = lugar.data.imagen || "/images/Elfheim-fondo2.jpg";
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{lugar.data.nombre} | Registro de Ubicación</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0c0617] text-[#cbd5e1] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="relative w-full h-[45vh] min-h-[350px] border-b border-[#3b82f6]/30 overflow-hidden">
        <img src={imagenFondo} alt={lugar.data.nombre} class="absolute inset-0 w-full h-full object-cover opacity-25 scale-105" />
        
        <div class="absolute inset-0 bg-gradient-to-t from-[#0c0617] via-[#0c0617]/70 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#0c0617]/80 via-transparent to-[#0c0617]/80"></div>
        
        <div class="absolute bottom-0 left-0 right-0 w-full max-w-4xl mx-auto px-6 md:px-12 pb-12 z-10 flex flex-col justify-end h-full">
            <a href={`/reinos/${lugar.data.reino}`} class="text-[11px] font-bold tracking-[0.2em] text-[#d4af37] hover:text-[#fef08a] transition-colors mb-6 inline-flex items-center gap-2 uppercase group w-fit">
                <span class="transform group-hover:-translate-x-1 transition-transform">←</span> VOLVER AL REINO
            </a>
            
            {lugar.data.tipo && (
                <span class="text-[#3b82f6] font-mono tracking-[0.25em] uppercase text-[10px] block mb-2 border border-[#3b82f6]/30 w-fit px-3 py-1 rounded backdrop-blur-sm bg-[#3b82f6]/10 font-bold">
                    Clasificación: {lugar.data.tipo}
                </span>
            )}
            <h1 class="text-5xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#f8fafc] via-[#e2e8f0] to-[#94a3b8] drop-shadow-[0_0_20px_rgba(255,255,255,0.1)] uppercase tracking-tight mt-2">
                {lugar.data.nombre}
            </h1>
        </div>
    </div>

    <main class="max-w-4xl mx-auto px-6 md:px-12 py-16">
        <div class="relative bg-[#140a24]/30 border border-[#3b82f6]/10 rounded-2xl p-8 md:p-12 backdrop-blur-sm">
            <div class="absolute top-0 left-8 w-32 h-[1px] bg-gradient-to-r from-transparent via-[#3b82f6]/60 to-transparent"></div>
            
            <h2 class="text-xs font-mono tracking-[0.25em] text-[#3b82f6] uppercase mb-10 flex items-center gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-[#3b82f6] animate-pulse"></span> Datos de Expedición
            </h2>
            
            <article class="lugar-tactico text-[#94a3b8] text-base md:text-lg leading-[2] font-light max-w-none">
                <Content />
            </article>
        </div>
    </main>
</body>
</html>

<style is:global>
    /* Estilos automáticos para el Markdown de los Lugares */
    .lugar-tactico p {
        margin-bottom: 1.5rem;
    }
    .lugar-tactico p:last-child {
        margin-bottom: 0;
    }
    .lugar-tactico h3 {
        color: #d4af37; /* Dorado */
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.875rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(212, 175, 55, 0.3);
        padding-bottom: 0.5rem;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        font-weight: bold;
    }
    /* Estilos para listas (viñetas) */
    .lugar-tactico ul {
        list-style-type: none;
        padding-left: 0;
        margin-bottom: 2rem;
    }
    .lugar-tactico li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }
    /* Cuadradito azul para las listas */
    .lugar-tactico li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.6rem;
        width: 6px;
        height: 6px;
        background-color: #3b82f6;
        border-radius: 1px;
    }
    /* Negritas con color celeste para destacar los nombres de zonas/entornos */
    .lugar-tactico strong {
        color: #60a5fa; /* Azul claro */
        font-weight: bold;
    }
</style>