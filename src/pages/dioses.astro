---
// src/pages/dioses.astro
import { getCollection } from 'astro:content';
import '../styles/global.css';

const dioses = await getCollection('dioses');
const title = "PANTEÓN DIVINO";
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0c0617] text-[#f8fafc] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="fixed inset-0 z-0 bg-[radial-gradient(circle_at_50%_10%,rgba(212,175,55,0.05),transparent_50%)] pointer-events-none"></div>

    <div class="relative z-10 container mx-auto px-6 py-12 max-w-5xl">
        
        <a href="/" class="text-[11px] font-bold tracking-[0.2em] text-[#d4af37] hover:text-[#fef08a] transition-colors mb-10 inline-flex items-center gap-2 uppercase group w-fit">
            <span class="transform group-hover:-translate-x-1 transition-transform">←</span> VOLVER AL PORTAL
        </a>

        <header class="mb-16 border-b border-[#d4af37]/20 pb-10">
            <span class="text-xs font-mono tracking-[0.25em] text-[#d4af37] uppercase block mb-3">Mitos Sagrados</span>
            <h1 class="text-5xl md:text-6xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#d4af37] to-[#fef08a] drop-shadow-[0_0_20px_rgba(212,175,55,0.3)] mb-4 uppercase">
                {title}
            </h1>
            <p class="text-lg text-[#94a3b8] max-w-2xl font-light leading-relaxed">
                Conoce a las entidades supremas que rigen los elementos y destinos de Elfheim.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {dioses.map(dios => (
                <a href={`/dioses/${dios.id}`} class="group relative block bg-[#140a24]/40 border border-[#d4af37]/20 hover:border-[#d4af37] rounded-xl p-5 backdrop-blur-md hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] transition-all duration-300 flex gap-6 cursor-pointer overflow-hidden">
                    
                    <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-[#d4af37]/5 rounded-full blur-2xl group-hover:bg-[#d4af37]/15 transition-all duration-500"></div>

                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-lg overflow-hidden border border-[#d4af37]/10 shrink-0 relative">
                        <img src={dios.data.imagen || "/images/Elfheim-fondo2.jpg"} alt={dios.data.nombre} class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    </div>

                    <div class="flex flex-col justify-between flex-grow py-1 relative z-10">
                        <div>
                            {dios.data.elemento && (
                                <span class="text-[10px] font-mono font-bold tracking-[0.2em] text-[#d4af37] uppercase block mb-1 opacity-80">{dios.data.elemento}</span>
                            )}
                            <h2 class="text-xl md:text-2xl font-bold text-[#f8fafc] group-hover:text-[#fef08a] transition-colors tracking-tight">{dios.data.nombre}</h2>
                        </div>
                        <span class="text-[11px] text-[#d4af37] font-bold tracking-widest uppercase mt-3 flex items-center gap-1 group-hover:text-[#fef08a] transition-colors">
                            Leer Dogma <span class="transform group-hover:translate-x-1 transition-transform">→</span>
                        </span>
                    </div>
                </a>
            ))}
        </div>
    </div>
</body>
</html>