---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const clases = await getCollection('clases');
    return clases.map(clase => ({
        params: { slug: clase.id },
        props: { clase },
    }));
}

const { clase } = Astro.props;
const { Content } = await render(clase);
const imagenFondo = clase.data.imagen || "/images/Elfheim-fondo2.jpg";
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{clase.data.nombre} | Clase</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0c0617] text-[#cbd5e1] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="relative w-full h-[50vh] min-h-[400px] border-b border-[#a855f7]/30">
        <img src={imagenFondo} alt={clase.data.nombre} class="absolute inset-0 w-full h-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0c0617] via-[#0c0617]/80 to-transparent"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(168,85,247,0.1),transparent_70%)]"></div>
        
        <div class="absolute bottom-0 left-0 w-full max-w-5xl mx-auto px-8 md:px-16 pb-12 z-10 flex flex-col justify-end h-full right-0">
            <a href="/personaje" class="text-xs font-bold tracking-widest text-[#a855f7] hover:text-[#f8fafc] transition-colors mb-6 inline-block uppercase drop-shadow-md">
                ← VOLVER AL COMPENDIO
            </a>
            <span class="text-[#d4af37] font-mono tracking-widest uppercase text-sm block mb-2 drop-shadow-md">Disciplina Militar de {clase.data.reino}</span>
            <h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#a855f7] to-[#d8b4fe] drop-shadow-[0_0_20px_rgba(168,85,247,0.4)] mb-6">
                {clase.data.nombre}
            </h1>
            
            {clase.data.pasiva_nombre && (
                <div class="inline-flex items-center gap-3 bg-[#2e1065]/80 backdrop-blur-md border border-[#a855f7]/50 px-6 py-3 rounded-lg shadow-[0_0_20px_rgba(168,85,247,0.2)]">
                    <span class="text-2xl">✨</span>
                    <div>
                        <span class="text-[#a855f7] text-[10px] font-bold tracking-widest uppercase block mb-1">HABILIDAD PASIVA</span>
                        <span class="text-[#d8b4fe] font-bold tracking-wider text-lg">{clase.data.pasiva_nombre}</span>
                    </div>
                </div>
            )}
        </div>
    </div>

    <main class="max-w-5xl mx-auto px-8 md:px-16 py-16">
        <article class="prose prose-invert prose-lg md:prose-xl prose-headings:text-[#a855f7] prose-a:text-[#d4af37] max-w-none prose-p:leading-relaxed prose-p:text-[#94a3b8] prose-strong:text-[#d8b4fe]">
            <Content />
        </article>
    </main>
</body>
</html>