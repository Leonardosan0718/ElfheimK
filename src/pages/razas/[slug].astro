---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const razas = await getCollection('razas');
    return razas.map(raza => ({
        params: { slug: raza.id },
        props: { raza },
    }));
}

const { raza } = Astro.props;
const { Content } = await render(raza);
const imagenFondo = raza.data.imagen || "/images/Elfheim-fondo2.jpg";
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{raza.data.nombre} | Raza</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0c0617] text-[#cbd5e1] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="relative w-full h-[50vh] min-h-[400px] border-b border-[#10b981]/30">
        <img src={imagenFondo} alt={raza.data.nombre} class="absolute inset-0 w-full h-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0c0617] via-[#0c0617]/80 to-transparent"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.1),transparent_70%)]"></div>
        
        <div class="absolute bottom-0 left-0 w-full max-w-5xl mx-auto px-8 md:px-16 pb-12 z-10 flex flex-col justify-end h-full right-0">
            <a href="/personaje" class="text-xs font-bold tracking-widest text-[#10b981] hover:text-[#f8fafc] transition-colors mb-6 inline-block uppercase drop-shadow-md">
                ← VOLVER AL COMPENDIO
            </a>
            <span class="text-[#d4af37] font-mono tracking-widest uppercase text-sm block mb-2 drop-shadow-md">Especie Endémica de {raza.data.reino}</span>
            <h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#10b981] to-[#34d399] drop-shadow-[0_0_20px_rgba(16,185,129,0.4)] mb-8">
                {raza.data.nombre}
            </h1>
            
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4 font-mono text-sm bg-[#140a24]/80 backdrop-blur-md p-6 rounded-xl border border-[#10b981]/30 shadow-[0_0_30px_rgba(16,185,129,0.1)]">
                <div class="flex flex-col"><span class="text-gray-500 text-xs mb-1">SALUD</span><span class="text-red-400 text-xl font-bold">{raza.data.salud}</span></div>
                <div class="flex flex-col"><span class="text-gray-500 text-xs mb-1">RESISTENCIA</span><span class="text-orange-400 text-xl font-bold">{raza.data.resistencia}</span></div>
                <div class="flex flex-col"><span class="text-gray-500 text-xs mb-1">FUERZA</span><span class="text-yellow-400 text-xl font-bold">{raza.data.fuerza}</span></div>
                <div class="flex flex-col"><span class="text-gray-500 text-xs mb-1">VELOCIDAD</span><span class="text-green-400 text-xl font-bold">{raza.data.velocidad}</span></div>
                <div class="flex flex-col"><span class="text-gray-500 text-xs mb-1">MANÁ</span><span class="text-blue-400 text-xl font-bold">{raza.data.mana}</span></div>
            </div>
        </div>
    </div>

    <main class="max-w-5xl mx-auto px-8 md:px-16 py-16">
        <article class="prose prose-invert prose-lg md:prose-xl prose-headings:text-[#10b981] prose-a:text-[#d4af37] max-w-none prose-p:leading-relaxed prose-p:text-[#94a3b8]">
            <Content />
        </article>
    </main>
</body>
</html>