---
// src/pages/bestiario.astro
import { getCollection } from 'astro:content';
import '../styles/global.css';

const monstruos = await getCollection('bestiario');
const title = "BESTIARIO DE ELFHEIM";

// 🧠 LÓGICA DE AGRUPACIÓN (Intacta): Reino -> Lugar -> Monstruos
const bestiarioAgrupado = monstruos.reduce((acc, monstruo) => {
    // Si algún monstruo no tiene reino o lugar, le ponemos uno por defecto para que no marque error
    const reino = monstruo.data.reino || "Regiones Inexploradas";
    const lugar = monstruo.data.lugar || "Paradero Desconocido";

    if (!acc[reino]) acc[reino] = {};
    if (!acc[reino][lugar]) acc[reino][lugar] = [];

    acc[reino][lugar].push(monstruo);
    return acc;
}, {});
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;700;900&display=swap" rel="stylesheet">
</head>

<body class="bg-[#0c0617] text-[#f8fafc] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="fixed inset-0 z-0 bg-[radial-gradient(circle_at_50%_10%,rgba(220,38,38,0.05),transparent_50%)] pointer-events-none"></div>

    <div class="relative z-10 container mx-auto px-6 py-12 max-w-6xl">
        
        <a href="/" class="text-[11px] font-bold tracking-[0.2em] text-red-400 hover:text-red-300 transition-colors mb-10 inline-flex items-center gap-2 uppercase group w-fit">
            <span class="transform group-hover:-translate-x-1 transition-transform">←</span> VOLVER AL PORTAL
        </a>

        <header class="mb-16 border-b border-red-950/40 pb-8">
            <span class="text-xs font-mono tracking-[0.25em] text-red-400 uppercase block mb-3">Registros de Amenaza</span>
            <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-red-200 via-red-400 to-amber-500 drop-shadow-[0_0_20px_rgba(239,68,68,0.2)] mb-4 uppercase">
                {title}
            </h1>
            <p class="text-lg text-[#94a3b8] max-w-2xl font-light leading-relaxed">
                Registros clasificados de criaturas y aberraciones. Clasificados por su territorio de origen y zona de avistamiento.
            </p>
        </header>

        {Object.keys(bestiarioAgrupado).length === 0 ? (
            <div class="p-12 text-center bg-[#140a24]/40 border border-red-950/30 rounded-xl backdrop-blur-sm">
                <p class="text-red-400/70 font-mono tracking-widest text-sm uppercase">No hay criaturas registradas en el códice todavía.</p>
            </div>
        ) : (
            <div class="space-y-24">
                {Object.entries(bestiarioAgrupado).map(([reino, lugares]) => (
                    <section class="w-full">
                        
                        <div class="mb-12">
                            <span class="text-xs font-mono tracking-widest text-red-500 uppercase block mb-2">Sector Principal</span>
                            <h2 class="text-5xl font-black text-[#f8fafc] border-b border-red-900/30 pb-4 inline-block pr-12 drop-shadow-lg uppercase tracking-tight">
                                {reino}
                            </h2>
                        </div>
                        
                        <div class="space-y-16">
                            {Object.entries(lugares).map(([lugar, bestias]) => (
                                <div class="ml-0 lg:ml-8 relative">
                                    
                                    <div class="flex items-center gap-4 mb-8">
                                        <div class="w-12 h-[2px] bg-red-500/40 hidden lg:block"></div>
                                        <h3 class="text-xl font-bold text-[#f8fafc] tracking-widest bg-red-950/20 backdrop-blur-md px-6 py-2 rounded-lg border border-red-500/20 shadow-[0_0_20px_rgba(239,68,68,0.05)] uppercase flex items-center gap-3">
                                            <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span> {lugar}
                                        </h3>
                                    </div>
                                    
                                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:pl-16 lg:border-l-2 border-red-900/20">
                                        {bestias.map((bestia: any) => (
                                            
                                            <a href={`/bestiario/${bestia.id}`} class="group relative block bg-[#140a24]/40 border border-red-950/50 hover:border-red-500/40 rounded-xl p-4 backdrop-blur-md hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(239,68,68,0.15)] transition-all duration-300 flex flex-col sm:flex-row gap-4 cursor-pointer overflow-hidden">
                                                
                                                <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-red-500/[0.02] group-hover:bg-red-500/[0.08] rounded-full blur-2xl transition-all duration-500"></div>

                                                <div class="w-full sm:w-24 h-40 sm:h-24 rounded-lg overflow-hidden border border-white/5 shrink-0 relative bg-red-950/20">
                                                    <img src={bestia.data.image || "/images/Elfheim-fondo2.jpg"} alt={bestia.data.name} class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
                                                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
                                                </div>

                                                <div class="flex flex-col justify-between flex-grow py-1 relative z-10">
                                                    <div>
                                                        <span class="text-[9px] font-mono font-bold tracking-widest text-red-500 uppercase block mb-1">
                                                            ⚠️ Amenaza
                                                        </span>
                                                        <h4 class="text-lg font-bold text-[#f8fafc] group-hover:text-red-400 transition-colors tracking-tight uppercase leading-tight line-clamp-2">
                                                            {bestia.data.name}
                                                        </h4>
                                                    </div>
                                                    
                                                    <span class="text-[10px] text-red-400 group-hover:text-red-300 font-bold tracking-widest uppercase mt-4 flex items-center gap-1 transition-colors">
                                                        Analizar <span class="transform group-hover:translate-x-1 transition-transform duration-300">→</span>
                                                    </span>
                                                </div>
                                            </a>

                                        ))}
                                    </div>

                                </div>
                            ))}
                        </div>
                    </section>
                ))}
            </div>
        )}

    </div>
</body>
</html>