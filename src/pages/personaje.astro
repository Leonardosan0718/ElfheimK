---
// src/pages/personaje.astro
import { getCollection } from 'astro:content';
import '../styles/global.css';

// 1. Traemos todas las razas y clases
const todasLasRazas = await getCollection('razas');
const todasLasClases = await getCollection('clases');

// 2. Lógica de agrupación por Reino
const compendioAgrupado = {};

// Agrupamos Razas
todasLasRazas.forEach(raza => {
    const reino = raza.data.reino || "Reino Desconocido";
    if (!compendioAgrupado[reino]) compendioAgrupado[reino] = { razas: [], clases: [] };
    compendioAgrupado[reino].razas.push(raza);
});

// Agrupamos Clases
todasLasClases.forEach(clase => {
    const reino = clase.data.reino || "Reino Desconocido";
    if (!compendioAgrupado[reino]) compendioAgrupado[reino] = { razas: [], clases: [] };
    compendioAgrupado[reino].clases.push(clase);
});

const title = "CREACIÓN DE PERSONAJES";
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;700;900&display=swap" rel="stylesheet">
</head>

<body class="bg-[#0c0617] text-[#f8fafc] font-['Urbanist'] antialiased min-h-screen">
    
    <div class="fixed inset-0 z-0 bg-[radial-gradient(circle_at_50%_10%,rgba(16,185,129,0.05),transparent_50%)] pointer-events-none"></div>

    <div class="relative z-10 container mx-auto px-6 py-12 max-w-7xl">
        
        <a href="/" class="text-xs font-bold tracking-widest text-[#d4af37] hover:text-[#f8fafc] transition-colors mb-8 inline-block">
            ← VOLVER AL PORTAL
        </a>

        <header class="mb-16 border-b border-[#10b981]/30 pb-8">
            <h1 class="text-4xl md:text-5xl font-black tracking-tighter text-[#10b981] mb-4 drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                {title}
            </h1>
            <p class="text-lg text-[#cbd5e1] max-w-2xl font-light">
                Registros detallados de las razas que habitan Elfheim y las disciplinas de combate de cada facción. Selecciona una para leer su trasfondo completo.
            </p>
        </header>

        {Object.keys(compendioAgrupado).length === 0 ? (
            <div class="p-12 text-center bg-[#1a0b2e] border border-[#3b0764] rounded-xl">
                <p class="text-[#94a3b8]">No hay registros de personajes en el códice todavía.</p>
            </div>
        ) : (
            <div class="space-y-24">
                {Object.entries(compendioAgrupado).map(([reino, datos]) => (
                    <section class="w-full relative">
                        
                        <div class="mb-12 sticky top-0 bg-[#0c0617]/90 backdrop-blur-md py-4 z-20 border-b border-[#d4af37]/20">
                            <span class="text-xs font-mono tracking-widest text-[#d4af37] uppercase block mb-1">Fuerzas del Reino</span>
                            <h2 class="text-5xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#d4af37] to-[#fef08a] drop-shadow-lg uppercase">
                                {reino}
                            </h2>
                        </div>

                        {datos.razas.length > 0 && (
                            <div class="mb-16">
                                <h3 class="text-2xl font-bold text-[#f8fafc] mb-6 flex items-center gap-3">
                                    <span class="text-[#10b981]">🧬</span> Razas Endémicas
                                </h3>
                                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                    {datos.razas.map(raza => (
                                        <a href={`/razas/${raza.id}`} class="block bg-[#140a24]/60 border border-[#10b981]/30 rounded-xl p-6 backdrop-blur-sm hover:border-[#10b981] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(16,185,129,0.2)] transition-all flex flex-col md:flex-row gap-6 cursor-pointer group">
                                            
                                            <div class="w-full md:w-1/3 h-48 rounded-lg overflow-hidden border border-[#ffffff]/10 shrink-0">
                                                <img src={raza.data.imagen || "/images/Elfheim-fondo2.jpg"} alt={raza.data.nombre} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
                                            </div>
                                            
                                            <div class="w-full">
                                                <h4 class="text-2xl font-bold text-[#10b981] mb-2 group-hover:text-[#34d399] transition-colors">{raza.data.nombre}</h4>
                                                <p class="text-[#94a3b8] text-sm mb-4 line-clamp-2">{raza.body}</p>
                                                
                                                <div class="space-y-2 text-xs font-mono">
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-red-400 w-24">Salud</span>
                                                        <div class="flex-grow bg-black/50 h-2 rounded ml-2 overflow-hidden"><div class="bg-red-500 h-full" style={`width: ${raza.data.salud}%`}></div></div>
                                                        <span class="ml-2 w-8 text-right">{raza.data.salud}</span>
                                                    </div>
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-orange-400 w-24">Resistencia</span>
                                                        <div class="flex-grow bg-black/50 h-2 rounded ml-2 overflow-hidden"><div class="bg-orange-500 h-full" style={`width: ${raza.data.resistencia}%`}></div></div>
                                                        <span class="ml-2 w-8 text-right">{raza.data.resistencia}</span>
                                                    </div>
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-yellow-400 w-24">Fuerza Física</span>
                                                        <div class="flex-grow bg-black/50 h-2 rounded ml-2 overflow-hidden"><div class="bg-yellow-500 h-full" style={`width: ${raza.data.fuerza}%`}></div></div>
                                                        <span class="ml-2 w-8 text-right">{raza.data.fuerza}</span>
                                                    </div>
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-green-400 w-24">Velocidad</span>
                                                        <div class="flex-grow bg-black/50 h-2 rounded ml-2 overflow-hidden"><div class="bg-green-500 h-full" style={`width: ${raza.data.velocidad}%`}></div></div>
                                                        <span class="ml-2 w-8 text-right">{raza.data.velocidad}</span>
                                                    </div>
                                                    <div class="flex justify-between items-center">
                                                        <span class="text-blue-400 w-24">Maná</span>
                                                        <div class="flex-grow bg-black/50 h-2 rounded ml-2 overflow-hidden"><div class="bg-blue-500 h-full" style={`width: ${raza.data.mana}%`}></div></div>
                                                        <span class="ml-2 w-8 text-right">{raza.data.mana}</span>
                                                    </div>
                                                </div>
                                            </div>

                                        </a>
                                    ))}
                                </div>
                            </div>
                        )}

                        {datos.clases.length > 0 && (
                            <div>
                                <h3 class="text-2xl font-bold text-[#f8fafc] mb-6 flex items-center gap-3">
                                    <span class="text-[#a855f7]">⚔️</span> Clases de Combate
                                </h3>
                                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                    {datos.clases.map(clase => (
                                        <a href={`/clases/${clase.id}`} class="block bg-[#140a24]/40 border border-[#a855f7]/30 rounded-xl p-6 backdrop-blur-sm hover:border-[#a855f7] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.2)] transition-all flex flex-col md:flex-row gap-6 cursor-pointer group">
                                            
                                            <div class="w-full md:w-1/3 h-48 rounded-lg overflow-hidden border border-[#ffffff]/10 shrink-0">
                                                <img src={clase.data.imagen || "/images/Elfheim-fondo2.jpg"} alt={clase.data.nombre} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
                                            </div>

                                            <div class="w-full flex flex-col justify-between">
                                                <div>
                                                    <h4 class="text-2xl font-bold text-[#f8fafc] mb-2 group-hover:text-[#d8b4fe] transition-colors">{clase.data.nombre}</h4>
                                                    
                                                    {clase.data.pasiva_nombre && (
                                                        <div class="bg-[#2e1065]/40 border border-[#a855f7]/20 rounded p-2 mb-3 inline-block">
                                                            <span class="text-[#d8b4fe] text-[10px] font-bold tracking-widest uppercase block">Pasiva: {clase.data.pasiva_nombre}</span>
                                                        </div>
                                                    )}
                                                </div>
                                                
                                                <p class="text-[#94a3b8] text-sm leading-relaxed line-clamp-3 mt-1">{clase.body}</p>
                                            </div>

                                        </a>
                                    ))}
                                </div>
                            </div>
                        )}

                    </section>
                ))}
            </div>
        )}

    </div>
</body>
</html>