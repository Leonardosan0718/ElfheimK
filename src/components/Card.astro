---
interface Props {
  name: string;
  image?: string;
  subtext?: string;
  href: string; 
}

const { name, image = "/images/placeholder.png", subtext = "Desconocido", href } = Astro.props;
---

<a 
  href={href} 
  class="group block bg-[#140a24]/60 border border-[#2e1065]/60 rounded-xl overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.4)] transition-all duration-500 hover:scale-[1.03] hover:border-[#d4af37] hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] backdrop-blur-sm"
>
  <div class="h-56 overflow-hidden bg-[#0c0617] relative">
    <img 
      src={image} 
      alt={name} 
      class="w-full h-full object-cover opacity-75 transition-all duration-700 ease-out group-hover:scale-110 group-hover:translate-y-[-4px] group-hover:opacity-100"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#140a24] via-[#140a24]/20 to-transparent"></div>
  </div>

  <div class="p-6 border-t border-[#2e1065]/20">
    <span class="text-[10px] font-mono tracking-widest text-[#d4af37]/80 uppercase block mb-1.5">
      {subtext}
    </span>
    <h3 class="text-2xl font-bold text-[#f8fafc] tracking-tight group-hover:text-[#d4af37] transition-colors duration-300">
      {name}
    </h3>
    
    <div class="mt-4 flex items-center text-xs font-bold tracking-wider text-[#a855f7] group-hover:text-[#d4af37] transition-colors duration-300">
      LEER CÓDICE <span class="transform translate-x-0 group-hover:translate-x-1 transition-transform duration-300 ml-1">→</span>
    </div>
  </div>
</a>